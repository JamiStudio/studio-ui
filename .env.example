# Studio UI Registry local development template.
# Copy to .env for local-only values. Do not commit .env.

STUDIO_REGISTRY_PUBLIC_URL=http://localhost:3000/r
STUDIO_REGISTRY_NAMESPACE=@jami-studio

# Optional publishing / hosting values.
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=
NPM_CONFIG_REGISTRY=https://registry.npmjs.org/

# Future app/runtime secrets belong in local .env or provider secret stores only.
