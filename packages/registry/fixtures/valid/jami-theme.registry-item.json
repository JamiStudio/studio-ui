{
  "$schema": "https://jami.studio/schemas/registry/registry-item.schema.json",
  "name": "@jami-studio/jami-theme",
  "type": "theme",
  "title": "Jami Factory Theme",
  "description": "Warm Jami factory theme: generated CSS variables, Tailwind @theme variables, TypeScript token names, and shadcn cssVars derived from the DTCG token source.",
  "suite": "solo",
  "dependencies": [],
  "registryDependencies": [],
  "files": [
    {
      "path": "packages/tokens/generated/jami.css",
      "target": "studio-ui/jami.css",
      "kind": "registry:theme"
    },
    {
      "path": "packages/tokens/generated/jami.tailwind.css",
      "target": "studio-ui/jami.tailwind.css",
      "kind": "registry:theme"
    },
    {
      "path": "packages/tokens/generated/jami-tokens.ts",
      "target": "studio-ui/jami-tokens.ts",
      "kind": "registry:lib"
    },
    {
      "path": "packages/tokens/generated/jami.shadcn.json",
      "target": "studio-ui/jami.shadcn.json",
      "kind": "registry:file"
    },
    {
      "path": "packages/tokens/generated/jami-token-provenance.json",
      "target": "studio-ui/jami-token-provenance.json",
      "kind": "registry:file"
    }
  ],
  "lifecycle": {
    "id": "theme.jami-factory",
    "version": "0.0.0-contract.20260609",
    "schemaVersion": "2026-06-09.registry-foundation",
    "sourceHash": "sha256:bf2adea14822eab1d092018d0767b31de75e3a19410905549576f5273f9c49ab",
    "migrationNotes": "Initial theme item. Files are the generated token outputs; regenerate with pnpm contracts:generate when the token source changes."
  },
  "tokenRequirements": [
    "semantic.light.background",
    "semantic.light.foreground",
    "semantic.light.accent",
    "semantic.dark.background",
    "semantic.dark.foreground",
    "componentState.focusRing"
  ],
  "provenance": {
    "source": "authored",
    "license": "MIT",
    "reviewedAt": "2026-06-09",
    "copiedSource": false
  },
  "compatibility": {
    "shadcn": "4.x source-lock required before generated output",
    "tailwind": "4.x source-lock required before generated output",
    "react": ">=19"
  }
}
